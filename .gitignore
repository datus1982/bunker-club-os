# dependencies
node_modules/
.pnpm-store/

# build output
dist/
apps/web/dist/
*.tsbuildinfo

# env & secrets — NEVER commit (docs/12 access hygiene)
.env
.env.*
!.env.example

# legacy export artifacts (produced by scripts/export-legacy.ts)
legacy-export/
backups/

# editor / OS
.DS_Store
.vscode/
.idea/

# supabase local
supabase/.branches/
supabase/.temp/

# legacy source zips — kept on disk, not tracked (re-downloadable from GitHub)
*.zip

# Lockfile: project standard is pnpm (docs decision 2), but this environment has no
# pnpm/corepack offline and installs + builds + deploys apps/web with npm (see CLAUDE.md).
# The npm package-lock.json is therefore the file that actually pins the deployed
# dependency state, so it is committed (Phase 1). Regenerate a pnpm-lock.yaml and switch
# back when a pnpm-capable environment is available.

# Ronnie's real trivia decks — large binaries, kept on disk only (CLAUDE.md)
docs/*.pptx
