# ─────────────────────────────────────────────────────────────────────────────
# Root env for scripts/ (export / import / seed / backup). NEVER commit real values.
# Service role key + Toast secrets live ONLY here + CI secrets, never in frontend
# (docs/12 access hygiene).
# ─────────────────────────────────────────────────────────────────────────────

# New (OWNED) Supabase project — used by import-legacy / seed-staff / backup.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres connection string for pg_dump backups (Supabase → Settings →
# Database → Connection string). Used by scripts/backup.ts.
DATABASE_URL=

# Legacy OptiDev project — READ-ONLY export via anon key (path B, docs/03).
# The project URL leaked in the legacy rls-policies.sql; the anon key is in the
# legacy apps' config. NEVER write to this project (it serves live Wednesdays).
LEGACY_SUPABASE_URL=https://cdgdxfichpikapawnnth.supabase.co
LEGACY_SUPABASE_ANON_KEY=

# The active venue id (seeded Bunker Club row, migration 0014).
VENUE_ID=11111111-1111-1111-1111-111111111111

# venue_staff seeding (run scripts/seed-staff.ts AFTER these people sign in once).
STAFF_ADMIN_EMAIL=
STAFF_HOST_EMAIL=

# Backup output dir (docs/12). Off-platform upload (R2/S3/Drive/GH artifact) is
# wired in CI; locally this just writes here.
BACKUP_DIR=./backups
